    e_answer_describe: "<p>sin&nbsp;<span class="math-tex">\(\theta\)</span> + cos&nbsp;<span class="math-tex">\(\theta\)</span> =&nbsp;<span class="math-tex">\(\sqrt2\)</span> cos <span class="math-tex">\(\theta\)</span></p>
    
    <p><span class="math-tex">\(\Rightarrow\)</span>&nbsp;sin&nbsp;<span class="math-tex">\(\theta\)</span>&nbsp;=&nbsp;(<span class="math-tex">\(\sqrt2\)</span>&nbsp;- 1) cos&nbsp;<span class="math-tex">\(\theta\)</span></p>
    
