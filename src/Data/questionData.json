    question_name: "<p>If cos A =&nbsp;<span class="math-tex">\(\frac{4}{5}\)</span>&nbsp;then the value of tan A is :</p>",
    option1: "<p><span class="math-tex">\(\frac{3}{5}\)</span></p>",
    option2: "<p><span class="math-tex">\(\frac{3}{4}\)</span></p>",
    option3: "<p><span class="math-tex">\(\frac{4}{3}\)</span></p>",
    option4: "<p><span class="math-tex">\(\frac{5}{3}\)</span></p>",
    option5: null,
