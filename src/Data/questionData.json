    status: 1,
    created_date: "2022-01-11 06:05:16",
    e_answer_describe: "<p><strong>Given,</strong></p>
    
    <p>cos A =&nbsp;<span class="math-tex">\(\frac{4}{5}\)</span>&nbsp;</p>
    
    <p><span class="math-tex">\(\therefore \)</span>&nbsp;sin A =&nbsp;<span class="math-tex">\(\sqrt{1-cos^2A}\)</span>&nbsp;</p>
    
    <p>[&nbsp;<span class="math-tex">\(\because\)</span>&nbsp;<span class="math-tex">\(sin^2A+cos^2A=1\)</span>]</p>
    
    <p>[&nbsp;<span class="math-tex">\(\therefore \)</span>&nbsp;sin A =&nbsp;<span class="math-tex">\(\sqrt{1-cos^2A}\)</span>]</p>
    
    <p>sin A =&nbsp;<span class="math-tex">\(\sqrt{1-(\frac{4}{5})^2}\)</span>&nbsp;</p>
    
    <p>=&nbsp;<span class="math-tex">\(\sqrt{1-\frac{16}{25}}\)</span>&nbsp;</p>
    
    <p>=&nbsp;<span class="math-tex">\(\sqrt{\frac{9}{25}}\)</span>&nbsp;</p>
    
    <p>=&nbsp;<span class="math-tex">\(\frac{3}{5}\)</span>&nbsp;</p>
    
    <p><strong>Now,</strong></p>
    
    <p>tan A =&nbsp;<span class="math-tex">\(\frac{sin\,A}{cos\,A}\)</span>&nbsp;</p>
    
    <p>=&nbsp;<span class="math-tex">\(\frac{\frac{3}{4}}{\frac{4}{5}}\)</span>&nbsp;</p>
    
    <p>=&nbsp;<span class="math-tex">\(\frac{3}{4}\)</span>&nbsp;</p>",
    e_question_describe: null,
