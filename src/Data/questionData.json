    question_name: "<p>If 6cot&nbsp;<span class="math-tex">\(\theta\)</span>&nbsp;+ 2cosec&nbsp;<span class="math-tex">\(\theta\)</span>&nbsp;= cot&nbsp;<span class="math-tex">\(\theta\)</span>&nbsp;+ 5cosec&nbsp;<span class="math-tex">\(\theta\)</span>, then&nbsp;<span class="math-tex">\(cos\,\theta\)</span>&nbsp;is</p>",
