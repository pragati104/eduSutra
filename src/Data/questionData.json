    e_answer_describe: "<p><strong>Given,&nbsp;</strong></p>
    
    <p>sin A =&nbsp;<span class="math-tex">\(\frac{1}{2}\)</span></p>
    
    <p><span class="math-tex">\(\Rightarrow\)</span>&nbsp;sin A =&nbsp;<span class="math-tex">\(sin30^{\circ}\)</span></p>
    
