    <p><span class="math-tex">\(\Rightarrow\)</span>&nbsp;<span class="math-tex">\(5\,cot\theta\)</span>&nbsp;=&nbsp;<span class="math-tex">\(3\,cosec\theta \)</span>&nbsp;</p>
    
    <p><span class="math-tex">\(\Rightarrow\)</span>&nbsp;<span class="math-tex">\(5\frac{cos\theta}{sin\theta}\)</span>&nbsp;=&nbsp;<span class="math-tex">\(3\frac{1}{sin\theta}\)</span>&nbsp;</p>
    
